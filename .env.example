# Copy to `.env` or `.env.local` and fill in values. Never commit real secrets.

# --- App ---
DATABASE_URL="file:./dev.db"
AUTH_SECRET=""
ADMIN_PASSWORD=""

# --- LINE 老師端（北部 / 南部各一組 Messaging API）---
# Channel secret / Channel access token from LINE Developers
LINE_NORTH_SECRET=""
LINE_NORTH_TOKEN=""
LINE_SOUTH_SECRET=""
LINE_SOUTH_TOKEN=""

# --- LINE 園所端（課程回報轉傳；測試時換另一組 OA 只要改這兩個變數）---
LINE_SCHOOL_SECRET=""
LINE_SCHOOL_TOKEN=""

# --- Cron（例如 /api/cron/reminder，Authorization: Bearer …）---
CRON_SECRET=""

# --- Optional: Turso ---
# TURSO_DATABASE_URL=""
# TURSO_AUTH_TOKEN=""

# --- Optional: 薪資條 email ---
# GMAIL_USER=""
# GMAIL_APP_PASSWORD=""
