generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model School {
  id                 Int      @id @default(autoincrement())
  name               String   @unique
  type               String   @default("")
  region             String   @default("")
  address            String   @default("")
  phone              String   @default("")
  contact            String   @default("")
  notes              String   @default("")
  lineUserId         String?
  lineBindCode       String?  @unique
  createdAt          DateTime @default(now())
  courses            Course[]
  invoices           SchoolInvoice[]
  startConfirmations SchoolStartConfirmation[]
}

model SchoolStartConfirmation {
  id                 Int      @id @default(autoincrement())
  school             School   @relation(fields: [schoolId], references: [id])
  schoolId           Int
  academicYear       Int
  semester           String
  smallClassCount    String   @default("")
  middleClassCount   String   @default("")
  bigClassCount      String   @default("")
  classLocation      String   @default("")
  classLocationOther String   @default("")
  rainyDayLocation   String   @default("")
  teachingStyles     String   @default("[]")
  classNotes         String   @default("")
  otherNotes         String   @default("")
  submittedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  history            SchoolStartConfirmationHistory[]

  @@unique([schoolId, academicYear, semester])
  @@index([schoolId])
  @@index([academicYear, semester])
}

model SchoolStartConfirmationHistory {
  id                         Int      @id @default(autoincrement())
  confirmation               SchoolStartConfirmation @relation(fields: [confirmationId], references: [id])
  confirmationId             Int
  updatedByTeacherId         Int?
  updatedByAdminId           Int?
  previousSmallClassCount    String   @default("")
  previousMiddleClassCount   String   @default("")
  previousLargeClassCount    String   @default("")
  newSmallClassCount         String   @default("")
  newMiddleClassCount        String   @default("")
  newLargeClassCount         String   @default("")
  note                       String   @default("")
  createdAt                  DateTime @default(now())

  @@index([confirmationId])
  @@index([updatedByTeacherId])
  @@index([createdAt])
}

model CourseProgress {
  id         Int      @id @default(autoincrement())
  courseType String
  lesson     Int
  title      String
  createdAt  DateTime @default(now())

  @@unique([courseType, lesson])
}

model LessonTemplate {
  id                Int      @id @default(autoincrement())
  courseType        String
  lesson            Int
  title             String
  focus             String   @default("")
  skills            String   @default("")
  activityDirection String   @default("")
  aiStyle           String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([courseType, lesson])
}

model CourseOption {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  label     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SkillCard {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  icon        String   @default("")
  imageUrl    String   @default("")
  description String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EquipmentStatus {
  id        Int      @id @default(autoincrement())
  schoolId  Int?
  school    String   @default("")
  name      String
  quantity  String   @default("")
  status    String   @default("正常")
  notes     String   @default("")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([school])
}

model UserAccount {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  name         String
  email        String   @default("")
  passwordHash String
  role         String   @default("admin")
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  actorUserId Int?
  actorName   String   @default("")
  actorRole   String   @default("")
  action      String
  targetType  String
  targetId    String   @default("")
  targetLabel String   @default("")
  beforeData  String   @default("")
  afterData   String   @default("")
  diffSummary String   @default("")
  ipAddress   String   @default("")
  userAgent   String   @default("")
  sensitive   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([action])
  @@index([targetType])
  @@index([createdAt])
  @@index([sensitive])
}

model Teacher {
  id                   Int          @id @default(autoincrement())
  name                 String       @unique
  rateAfterSchool      Int          @default(500)
  rateInSchool         Int          @default(500)
  rateDemo             Int          @default(200)
  travelFee            Int          @default(0)
  isAssistant          Boolean      @default(false)
  assistantFee         Int          @default(0)
  notes                String       @default("")
  email                String       @default("")
  phone                String       @default("")
  bankName             String       @default("")
  bankCode             String       @default("")
  bankBranch           String       @default("")
  bankAccountName      String       @default("")
  bankAccountNumber    String       @default("")
  lineUserId           String?      @unique
  lineBindCode         String?      @unique
  lineRegion           String       @default("")
  createdAt            DateTime     @default(now())
  courses              Course[]
  assistantCourses     Course[]     @relation("AssistantTeacher")
  attendances          Attendance[] @relation("ActualTeacher")
  assistantAttendances Attendance[] @relation("AssistantAttendance")
  substitutions        Substitute[] @relation("SubstituteTeacher")
  absences             Substitute[] @relation("OriginalTeacher")
  salaryAdjustments    SalaryAdjustment[]
  leaveRequests        TeacherLeaveRequest[] @relation("LeaveTeacher")
  substituteInquiries  SubstituteInquiry[]   @relation("InquiryCandidateTeacher")
}

model SalaryAdjustment {
  id          Int      @id @default(autoincrement())
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId   Int
  targetMonth String
  payoutMonth String
  type        String   @default("補發")
  amount      Int
  reason      String
  notes       String   @default("")
  isPaid      Boolean  @default(false)
  paidAt      DateTime?
  createdBy   String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teacherId, payoutMonth])
  @@index([payoutMonth])
  @@index([targetMonth])
  @@index([isPaid])
}

model Course {
  id                 Int          @id @default(autoincrement())
  code               String       @unique
  region             String       @default("")
  teacher            Teacher      @relation(fields: [teacherId], references: [id])
  teacherId          Int
  assistantTeacher   Teacher?     @relation("AssistantTeacher", fields: [assistantTeacherId], references: [id])
  assistantTeacherId Int?
  school             String
  schoolId           Int?
  schoolRel          School?      @relation(fields: [schoolId], references: [id])
  courseType         String
  address            String       @default("")
  dayOfWeek          String       @default("")
  recurrenceType     String       @default("")
  startDate          DateTime?
  endDate            DateTime?
  weekday            String       @default("")
  time               String       @default("")
  payrollHours       Float?
  category           String       @default("課後")
  department         String       @default("幼兒園")
  enrollCount        String       @default("")
  isActive           Boolean      @default(true)
  notes              String       @default("")
  createdAt          DateTime     @default(now())
  attendances        Attendance[]
  scheduleExceptions CourseScheduleException[]
  leaveRequests      TeacherLeaveRequest[]

  @@index([schoolId])
  @@index([teacherId])
  @@index([isActive])
  @@index([department])
}

model CourseScheduleException {
  id              Int      @id @default(autoincrement())
  course          Course   @relation(fields: [courseId], references: [id])
  courseId        Int
  date            DateTime
  type            String
  replacementDate DateTime?
  notes           String   @default("")
  createdAt       DateTime @default(now())

  @@index([courseId, date])
  @@index([type])
}

model Attendance {
  id                 Int                      @id @default(autoincrement())
  date               DateTime
  course             Course                   @relation(fields: [courseId], references: [id])
  courseId           Int
  actualTeacher      Teacher                  @relation("ActualTeacher", fields: [actualTeacherId], references: [id])
  actualTeacherId    Int
  assistantTeacher   Teacher?                 @relation("AssistantAttendance", fields: [assistantTeacherId], references: [id])
  assistantTeacherId Int?
  studentCount       Int?
  studentCountA      Int?
  studentCountB      Int?
  cancelled          Boolean                  @default(false)
  cancelReason       String                   @default("")
  makeupDate         DateTime?
  makeupDone         Boolean                  @default(false)
  category           String                   @default("課後")
  hours              Float                    @default(1)
  scheduledTime      String?                  @default("")
  isPayrollLocked    Boolean                  @default(false)
  payrollLockedAt    DateTime?
  notes              String                   @default("")
  reportContent      String                   @default("")
  reportSentAt       DateTime?
  schoolNotifyStatus String                   @default("未通知")
  schoolNotifyError  String                   @default("")
  schoolNotifiedAt   DateTime?
  skillFocus         String                   @default("")
  classStatus        String                   @default("")
  incident           Boolean                  @default(false)
  incidentChild      String                   @default("")
  incidentProcess    String                   @default("")
  incidentAction     String                   @default("")
  incidentNotified   String                   @default("")
  reportPhotos       String                   @default("")
  aiSummary          String                   @default("")
  aiSkillFocus       String                   @default("")
  aiTeachingNote     String                   @default("")
  createdAt          DateTime                 @default(now())
  assessments        KindergartenAssessment[]
  substitutes        Substitute[]
  leaveRequests      TeacherLeaveRequest[]
  substituteInquiries SubstituteInquiry[]

  @@unique([courseId, date])
  @@index([date])
  @@index([actualTeacherId])
  @@index([assistantTeacherId])
  @@index([isPayrollLocked])
  @@index([cancelled])
  @@index([category])
}

model KindergartenAssessment {
  id                 Int        @id @default(autoincrement())
  attendance         Attendance @relation(fields: [attendanceId], references: [id])
  attendanceId       Int
  childName          String
  semester           String     @default("")
  courseName         String     @default("")
  scores             String     @default("")
  comment            String     @default("")
  title              String     @default("")
  certificatePayload String     @default("")
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([attendanceId])
}

model Substitute {
  id                  Int         @id @default(autoincrement())
  attendance          Attendance? @relation(fields: [attendanceId], references: [id], onDelete: SetNull)
  attendanceId        Int?
  role                String      @default("主教")
  date                DateTime
  school              String
  courseType          String      @default("")
  originalTeacher     Teacher     @relation("OriginalTeacher", fields: [originalTeacherId], references: [id])
  originalTeacherId   Int
  substituteTeacher   Teacher?    @relation("SubstituteTeacher", fields: [substituteTeacherId], references: [id])
  substituteTeacherId Int?
  confirmed           Boolean     @default(false)
  fee                 Int?
  notes               String      @default("")
  createdAt           DateTime    @default(now())

  @@unique([attendanceId, role])
  @@index([attendanceId])
}

model TeacherLeaveRequest {
  id                         Int                 @id @default(autoincrement())
  teacher                    Teacher             @relation("LeaveTeacher", fields: [teacherId], references: [id])
  teacherId                  Int
  attendance                 Attendance          @relation(fields: [attendanceId], references: [id])
  attendanceId               Int
  course                     Course              @relation(fields: [courseId], references: [id])
  courseId                   Int
  role                       String              @default("主教")
  leaveDate                  DateTime
  startTime                  String              @default("")
  endTime                    String              @default("")
  reason                     String
  notes                      String              @default("")
  status                     String              @default("待審核")
  semesterLeaveCountAtSubmit Int                 @default(0)
  reviewedBy                 String              @default("")
  reviewedAt                 DateTime?
  rejectedReason             String              @default("")
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  inquiries                  SubstituteInquiry[]

  @@index([teacherId, leaveDate])
  @@index([attendanceId])
  @@index([courseId])
  @@index([status])
}

model SubstituteInquiry {
  id                 Int                 @id @default(autoincrement())
  leaveRequest       TeacherLeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  leaveRequestId     Int
  attendance         Attendance          @relation(fields: [attendanceId], references: [id])
  attendanceId       Int
  candidateTeacher   Teacher             @relation("InquiryCandidateTeacher", fields: [candidateTeacherId], references: [id])
  candidateTeacherId Int
  status             String              @default("pending")
  sentAt             DateTime?
  respondedAt        DateTime?
  lineMessageId      String              @default("")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([leaveRequestId, candidateTeacherId])
  @@index([attendanceId])
  @@index([candidateTeacherId])
  @@index([status])
}

model SchoolInvoice {
  id           Int                 @id @default(autoincrement())
  school       School              @relation(fields: [schoolId], references: [id])
  schoolId     Int
  schoolName   String
  brandName    String
  invoiceMonth String
  invoiceDate  DateTime            @default(now())
  status       String              @default("已產生")
  totalAmount  Int                 @default(0)
  taxType      String              @default("未稅")
  notes        String              @default("")
  companyName  String              @default("威斯博國際股份有限公司")
  phone        String              @default("")
  fax          String              @default("")
  bankName     String              @default("")
  bankAccount  String              @default("")
  accountName  String              @default("威斯博國際股份有限公司")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  items        SchoolInvoiceItem[]

  @@index([schoolId, invoiceMonth])
  @@index([invoiceMonth])
  @@index([status])
}

model SchoolInvoiceItem {
  id          Int                   @id @default(autoincrement())
  invoice    SchoolInvoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId  Int
  courseType String
  courseName String
  periodLabel String
  billingType String                 @default("perClass")
  unitPrice  Int                   @default(0)
  minChargeCount Int                @default(0)
  quantity   Int                   @default(0)
  quantityLabel String              @default("堂")
  actualStudentCount Int            @default(0)
  billableCount Int                 @default(0)
  subtotal   Int                   @default(0)
  note       String                @default("")
  details    SchoolInvoiceDetail[]

  @@index([invoiceId])
}

model SchoolInvoiceDetail {
  id            Int               @id @default(autoincrement())
  invoiceItem   SchoolInvoiceItem @relation(fields: [invoiceItemId], references: [id], onDelete: Cascade)
  invoiceItemId Int
  attendanceId  Int?
  date          DateTime
  weekday       String
  time          String            @default("")
  hours         Float             @default(0)
  studentCount  Int?
  billableCount Int?
  note          String            @default("")

  @@index([invoiceItemId])
  @@index([attendanceId])
}
